# ─── Server (Render.com uses PORT automatically) ──────────────────────────────
PORT=3000

# ─── Tor proxy (local only — used by: npm run tor) ────────────────────────────

# Where to forward .onion traffic to
# Leave as localhost:3000 if running the server locally
# Or point to your live Render site:
#   TARGET_HOST=tor-website.onrender.com
#   TARGET_PORT=443
TARGET_HOST=localhost
TARGET_PORT=3000

# Tor control port (default is fine)
TOR_CONTROL_PORT=9051

# Windows only: full path to tor.exe from the Tor Expert Bundle
# Download: https://www.torproject.org/download/tor/
# Example:
#   TOR_PATH=C:\Users\YourName\Downloads\tor-expert-bundle\tor\tor.exe
# TOR_PATH=
