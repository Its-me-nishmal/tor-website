{
  "name": "tor-hello-world",
  "version": "1.0.0",
  "description": "A simple Node.js Hello World server hosted on Render.com with Tor onion link support",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "tor": "node src/tor-proxy.js",
    "start:tor": "concurrently --names \"SERVER,TOR\" --prefix-colors \"cyan,magenta\" \"node src/index.js\" \"node src/tor-proxy.js\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.4.5",
    "granax": "3.2.9"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}